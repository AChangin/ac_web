              "type": "blur",
              "amount": 20,
              "duration": 1,
              "delay": 0,
              "ease": "cubic"
            }
          ]
        },
        {
          "type": "text",
          "content": "我们现今的状态没有灾难，但也没有一个可预见的未来。放早几年之前，可能还有人说这是危言耸听，可是现今的消费降级、劳工生存日益艰难以及全球保守主义抬头，更别说AI与人类劳动在将岗位上的愈演愈烈的争夺……",
          "x": "250vw",
          "width": "75vw",
          "fontFamily": "'Inter', sans-serif",
          "fontSize": "2rem",
          "fontWeight": "300",
          "color": "#fff",
          "zIndex": 2,
          "id": "el_o7ebser3",
          "_inspectorPushed": true,
          "marginTop": "35vh",
          "lineHeight": 1.4,
